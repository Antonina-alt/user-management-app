NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_manager_db
DB_USER=postgres
DB_PASSWORD=database_password

# JWT / tokens
JWT_SECRET=long_random_secret_at_least_32_chars
EMAIL_CONFIRMATION_SECRET=another_long_random_secret_at_least_32_chars

# App URLs
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:5000

# SENDGRID_API
SENDGRID_API_KEY=sendgrid_api_key
MAIL_FROM="User Manager <verified_sender_email@example.com>"