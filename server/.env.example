NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_manager_db
DB_USER=postgres
DB_PASSWORD=your_database_password

# JWT / tokens
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
EMAIL_CONFIRMATION_SECRET=replace_with_another_long_random_secret_at_least_32_chars

# App URLs
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:5000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="User Manager <your_email@gmail.com>"